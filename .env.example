# Copy to .env and fill in, then `source .env`. Both the single-judge audit and the
# multi-judge comparison read these. Any OpenAI-compatible endpoint works.

# =========================================================================
# Single-judge audit (scripts/run_audit.sh) — one judge + one generator
# =========================================================================
# --- Judge model (the LLM-as-judge under audit) ---
export OC_JUDGE_MODEL=deepseek-chat
export OC_JUDGE_API_KEY=sk-your-key-here
export OC_JUDGE_API_BASE=https://api.deepseek.com/v1

# --- Answer generator (builds the A/B candidate answers) ---
# Defaults to the judge model/endpoint if unset.
export OC_GEN_MODEL=deepseek-chat
export OC_GEN_API_KEY=sk-your-key-here
export OC_GEN_API_BASE=https://api.deepseek.com/v1

# =========================================================================
# Multi-judge comparison (scripts/run_compare.sh) — keys per provider
# configs/models.py refers to these by NAME; set only the ones you want to run.
# =========================================================================
export DEEPSEEK_API_KEY=sk-your-deepseek-key       # answer generator + a judge; https://api.deepseek.com/v1
export OPENAI_API_KEY=sk-your-openai-key           # ChatGPT   https://api.openai.com/v1
export ANTHROPIC_API_KEY=sk-ant-your-key           # Claude judge + QUESTION generator; https://api.anthropic.com/v1/
export GEMINI_API_KEY=your-google-ai-studio-key    # Gemini    .../v1beta/openai/
export MOONSHOT_API_KEY=sk-your-moonshot-key        # Kimi      https://api.moonshot.ai/v1
