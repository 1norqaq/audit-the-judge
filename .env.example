# Copy to .env and fill in. The judge + answer-generation calls read these.
# Any OpenAI-compatible endpoint works (DeepSeek shown; swap for OpenAI/vLLM/etc.).

# --- Judge model (the LLM-as-judge under audit) ---
export OC_JUDGE_MODEL=deepseek-chat
export OC_JUDGE_API_KEY=sk-your-key-here
export OC_JUDGE_API_BASE=https://api.deepseek.com/v1

# --- Answer generator (builds the A/B candidate answers) ---
# Defaults to the judge model/endpoint if unset.
export OC_GEN_MODEL=deepseek-chat
export OC_GEN_API_KEY=sk-your-key-here
export OC_GEN_API_BASE=https://api.deepseek.com/v1
